function GetRecommendation() {
  const [recommendation, setRecommendation] = useState(null);

  const fetchRecommendation = async () => {
    const response = await fetch('/api/get-recommendation');
    const data = await response.json();
    setRecommendation(data);
  };

  return (
    <div>
      <button onClick={fetchRecommendation}>Find My Song</button>
      {recommendation && (
        <div>
          <h3>Your Daily Recommendation:</h3>
          <p>{recommendation.name} by {recommendation.artist}</p>
          {/* Add play button or link to Spotify */}
        </div>
      )}
    </div>
  );
}
```

